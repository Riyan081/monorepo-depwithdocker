{
  "name": "todo-app",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate":"cd packages/db && npx prisma generate && cd ../..",
    "start:web":"cd apps/web && bun run start",
    "start:ws":"cd apps/ws-server && bun run dev",
    "start:https":"cd apps/https && bun run dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/ws": "^8.18.1",
    "ws": "^8.20.0"
  }
}
